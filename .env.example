APP_NAME=JotiGames Backend
APP_ENV=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api

# Reuse the same DB as frontend
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/jotigames

# Existing user table mapping (adjust to your frontend schema)
AUTH_USERS_TABLE=user
AUTH_USER_ID_COLUMN=id
AUTH_USERNAME_COLUMN=email
AUTH_USER_DISPLAY_NAME_COLUMN=username
AUTH_PASSWORD_COLUMN=password
AUTH_USER_ROLES_COLUMN=roles
AUTH_USER_IS_VERIFIED_COLUMN=is_verified
AUTH_USER_EMAIL_VERIFICATION_TOKEN_COLUMN=email_verification_token
AUTH_USER_EMAIL_VERIFICATION_REQUESTED_AT_COLUMN=email_verification_requested_at
AUTH_USER_PENDING_EMAIL_COLUMN=pending_email
AUTH_USER_PASSWORD_RESET_TOKEN_COLUMN=password_reset_token
AUTH_USER_PASSWORD_RESET_REQUESTED_AT_COLUMN=password_reset_requested_at

# Existing teams table mapping (adjust to your frontend schema)
AUTH_TEAMS_TABLE=team
AUTH_TEAM_ID_COLUMN=id
AUTH_TEAM_CODE_COLUMN=code
AUTH_TEAM_GAME_ID_COLUMN=game_id
AUTH_TEAM_NAME_COLUMN=name

AUTH_GAMES_TABLE=game
AUTH_GAME_ID_COLUMN=id
AUTH_GAME_CODE_COLUMN=code

TOKEN_TTL_MINUTES=43200

DEFAULT_LOCALE=en
TRANSLATIONS_DIR=translations/locales

# URL used in verification emails
APP_PUBLIC_BASE_URL=http://localhost:8000
AUTH_VERIFY_PATH=/api/auth/verify
AUTH_PASSWORD_RESET_PATH=/reset-password

# WS server integration (admin API key based)
# Preferred: single full backend->WS websocket URL
WS_EVENTS_URL=ws://localhost:3001/

# Backward-compatible alternatives (optional)
WS_BASE_URL=
WS_PROTOCOL=http
WS_HOST=
WS_PORT=
WS_BASE_PATH=
WS_EVENT_PATH=/admin/events
WS_TO_BACKEND_API_KEY=change-me-ws-to-backend
BACKEND_TO_WS_API_KEY=change-me-backend-to-ws

# SMTP DSN examples:
# smtp://user:password@smtp.example.com:587
# smtps://user:password@smtp.example.com:465
MAILER_DSN=
MAILER_FROM=

# TLS (optional)
SSL_CERTFILE=
SSL_KEYFILE=
SSL_KEYFILE_PASSWORD=

# ── Monetisation / Billing ──────────────────────────────────
ENABLE_MONETISATION=true
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=eur
